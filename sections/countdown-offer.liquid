<section
  class="countdown-offer"
  data-countdown-offer
  data-end-date="{{ section.settings.end_date }}"
>
  <div class="page-width">
    <div class="countdown-offer__top">
      <div class="countdown-offer__timer" data-countdown>
        <div class="countdown-offer__time-item">
          <span class="countdown-offer__number" data-days>200</span>
          <span class="countdown-offer__label">DAYS</span>
        </div>

        <span class="countdown-offer__separator">:</span>

        <div class="countdown-offer__time-item">
          <span class="countdown-offer__number" data-hours>11</span>
          <span class="countdown-offer__label">HRS</span>
        </div>

        <span class="countdown-offer__separator">:</span>

        <div class="countdown-offer__time-item">
          <span class="countdown-offer__number" data-minutes>43</span>
          <span class="countdown-offer__label">MIN</span>
        </div>

        <span class="countdown-offer__separator">:</span>

        <div class="countdown-offer__time-item">
          <span class="countdown-offer__number" data-seconds>14</span>
          <span class="countdown-offer__label">SEC</span>
        </div>
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="countdown-offer__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="countdown-offer__grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="countdown-offer__card"
          {{ block.shopify_attributes }}
        >
          <div
            class="countdown-offer__card-bg"
            {% if block.settings.background_image != blank %}
              style="
                background-image: url('{{ block.settings.background_image | image_url: width: 1800 }}');
                background-position: {{ block.settings.background_position }};
              "
            {% endif %}
          ></div>

          <div class="countdown-offer__card-overlay"></div>

          <div class="countdown-offer__card-content">
            {% if block.settings.eyebrow != blank %}
              <p class="countdown-offer__card-eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h3 class="countdown-offer__card-heading">{{ block.settings.heading }}</h3>
            {% endif %}

            {% if block.settings.button_label != blank %}
              <span class="countdown-offer__card-link">{{ block.settings.button_label }}</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Countdown offer",
  "tag": "section",
  "class": "section-countdown-offer",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "end_date",
      "label": "Countdown end date",
      "info": "Use format: 2026-12-31T23:59:59",
      "default": "2026-12-31T23:59:59"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Top button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Top button link"
    }
  ],
  "blocks": [
    {
      "type": "offer_card",
      "name": "Offer card",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "SECURITY CAMERA"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Up to 72% Off mega offer"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Buy Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "background_position",
          "label": "Background position",
          "default": "center center",
          "options": [
            { "value": "left center", "label": "Left center" },
            { "value": "center center", "label": "Center center" },
            { "value": "right center", "label": "Right center" },
            { "value": "center top", "label": "Center top" },
            { "value": "center bottom", "label": "Center bottom" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Countdown offer",
      "blocks": [
        { "type": "offer_card" },
        { "type": "offer_card" },
        { "type": "offer_card" }
      ]
    }
  ]
}
{% endschema %}