<section class="instagram-gallery">
  <div class="instagram-gallery__header">
    {% if section.settings.heading != blank %}
      <h2 class="instagram-gallery__heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="instagram-gallery__grid">
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="instagram-gallery__item"
        {% if block.settings.link != blank %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
        {{ block.shopify_attributes }}
      >
        <div class="instagram-gallery__image-wrap">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'instagram-gallery__image',
                loading: 'lazy',
                alt: section.settings.heading
            }}
          {% else %}
            <div class="instagram-gallery__placeholder"></div>
          {% endif %}

          <div class="instagram-gallery__overlay">
            <span class="instagram-gallery__icon">
              {% render 'icon', icon: 'instagram' %}
            </span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Instagram gallery",
  "tag": "section",
  "class": "section-instagram-gallery",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Instagram Shop"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram post link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram gallery",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}