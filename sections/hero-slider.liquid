<section class="hero-slider" data-hero-slider>
  <div class="hero-slider__viewport">
    <div class="hero-slider__track" data-hero-track>
      {% for block in section.blocks %}
        <article class="hero-slide" data-hero-slide {{ block.shopify_attributes }}>
          <!-- Slide background -->
          <div class="hero-slide__bg">
            {% if block.settings.background_image != blank %}
              {{
                block.settings.background_image
                | image_url: width: 2400
                | image_tag: class: 'hero-slide__bg-image', loading: 'eager', alt: block.settings.heading
              }}
            {% endif %}
            <div class="hero-slide__overlay"></div>
          </div>

          <div class="hero-slide__inner">
            <!-- Decorative text behind product -->
            {% if block.settings.decorative_text != blank %}
              <span class="hero-slide__decorative-text">
                {{ block.settings.decorative_text }}
              </span>
            {% endif %}

            <!-- Main product image -->
            {% if block.settings.product_image != blank %}
              <div class="hero-slide__media">
                {{
                  block.settings.product_image
                  | image_url: width: 1800
                  | image_tag: class: 'hero-slide__product-image', loading: 'eager', alt: block.settings.heading
                }}
              </div>
            {% endif %}

            <!-- Text content -->
            <div class="hero-slide__content">
              {% if block.settings.eyebrow != blank %}
                <p class="hero-slide__eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h1 class="hero-slide__heading">{{ block.settings.heading }}</h1>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="hero-slide__text">
                  {{ block.settings.text }}
                </div>
              {% endif %}

              <div class="hero-slide__buttons">
                {% if block.settings.primary_button_label != blank %}
                  <a
                    href="{{ block.settings.primary_button_link | default: '#' }}"
                    class="hero-btn hero-btn--primary"
                  >
                    {{ block.settings.primary_button_label }}
                  </a>
                {% endif %}

                {% if block.settings.secondary_button_label != blank %}
                  <a
                    href="{{ block.settings.secondary_button_link | default: '#' }}"
                    class="hero-btn hero-btn--secondary"
                  >
                    {{ block.settings.secondary_button_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>

    {% if section.settings.show_arrows and section.blocks.size > 1 %}
      <div class="hero-slider__controls">
        <button
          type="button"
          class="hero-slider__arrow hero-slider__arrow--prev"
          data-hero-prev
          aria-label="Previous slide"
        >
          {% render 'icon', icon: 'arrow-left' %}
        </button>

        <button
          type="button"
          class="hero-slider__arrow hero-slider__arrow--next"
          data-hero-next
          aria-label="Next slide"
        >
          {% render 'icon', icon: 'arrow-right' %}
        </button>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero slider",
  "tag": "section",
  "class": "section-hero-slider",
  "max_blocks": 8,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },

        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "DISCOUNT UPTO 75%, HURRY UP!"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Next generation Virtual reality"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>VR is the most quick access to notifications, calls, messages, apps right on your wrist, reducing the constantly check.</p>"
        },
        {
          "type": "text",
          "id": "primary_button_label",
          "label": "Primary button label",
          "default": "Buy Now"
        },
        {
          "type": "url",
          "id": "primary_button_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "secondary_button_label",
          "label": "Secondary button label",
          "default": "View More"
        },
        {
          "type": "url",
          "id": "secondary_button_link",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [{ "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
