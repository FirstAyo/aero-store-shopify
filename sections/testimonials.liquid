<section class="testimonials-section">
  <div class="page-width">
    <div class="testimonials-section__top">
      <div class="testimonials-section__intro">
        {% if section.settings.heading != blank %}
          <h2 class="testimonials-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="testimonials-section__text">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>

      <div class="testimonials-section__nav">
        <button
          type="button"
          class="testimonials-section__arrow testimonials-section__arrow--prev"
          data-testimonials-prev
          aria-label="Previous testimonials"
        >
          {% render 'icon', icon: 'arrow-left' %}
        </button>

        <button
          type="button"
          class="testimonials-section__arrow testimonials-section__arrow--next"
          data-testimonials-next
          aria-label="Next testimonials"
        >
          {% render 'icon', icon: 'arrow-right' %}
        </button>
      </div>
    </div>

    <div
      class="testimonials-section__viewport"
      data-testimonials-viewport
    >
      <div
        class="testimonials-section__track"
        data-testimonials-track
      >
        {% for block in section.blocks %}
          <article class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__rating">
              {% assign rating_value = block.settings.rating | default: 5 %}
              {% for i in (1..5) %}
                <span class="testimonial-card__star {% if i > rating_value %}is-inactive{% endif %}">★</span>
              {% endfor %}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="testimonial-card__title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.quote != blank %}
              <div class="testimonial-card__quote">
                {{ block.settings.quote }}
              </div>
            {% endif %}

            <div class="testimonial-card__author">
              {% if block.settings.name != blank %}
                <p class="testimonial-card__name">{{ block.settings.name }}</p>
              {% endif %}

              {% if block.settings.role != blank %}
                <p class="testimonial-card__role">{{ block.settings.role }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Client’s Happiness"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>The Best electronics products continue to drive innovation and shape the way we live, work, and interact with our environment.</p>"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Smart Home Assistant"
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>“This smart home assistant has become very important part of my daily routine. From managing my schedule and setting reminders to controlling smart home devices and answering questions.”</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Brain Armstrong"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Reviewer role/company",
          "default": "CEO Deplex Group"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }]
    }
  ]
}
{% endschema %}
