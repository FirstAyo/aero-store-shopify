<section class="promo-card-row">
  <div class="promo-card-row__grid">
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.button_link | default: '#' }}"
        class="promo-card promo-card--{{ forloop.index }}"
        {{ block.shopify_attributes }}
      >
        <div
          class="promo-card__bg"
          {% if block.settings.background_image != blank %}
            style="
              background-image: url('{{ block.settings.background_image | image_url: width: 1600 }}');
              background-position: {{ block.settings.background_position }};
            "
          {% endif %}
        ></div>

        <div class="promo-card__overlay"></div>

        <div class="promo-card__content">
          {% if block.settings.eyebrow != blank %}
            <p class="promo-card__eyebrow">{{ block.settings.eyebrow }}</p>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h3 class="promo-card__heading">{{ block.settings.heading }}</h3>
          {% endif %}

          {% if block.settings.button_label != blank %}
            <span class="promo-card__link">{{ block.settings.button_label }}</span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Promo card row",
  "tag": "section",
  "class": "section-promo-card-row",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Promo card",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "NEW ARRIVAL"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Latest Qpad with keyboard"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Buy Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "select",
          "id": "background_position",
          "label": "Background position",
          "default": "center center",
          "options": [
            { "value": "left center", "label": "Left center" },
            { "value": "center center", "label": "Center center" },
            { "value": "right center", "label": "Right center" },
            { "value": "center top", "label": "Center top" },
            { "value": "center bottom", "label": "Center bottom" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo card row",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
