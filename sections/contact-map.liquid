<section class="contact-map">
  <div class="page-width">
    <div class="contact-map__embed">
      {{ section.settings.map_embed }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact map",
  "tag": "section",
  "class": "section-contact-map",
  "settings": [
    {
      "type": "html",
      "id": "map_embed",
      "label": "Map embed code",
      "default": "<iframe src=\"https://www.google.com/maps?q=New+York&z=13&output=embed\" width=\"100%\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>"
    }
  ],
  "presets": [
    {
      "name": "Contact map"
    }
  ]
}
{% endschema %}
