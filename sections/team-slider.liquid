<section class="team-slider" data-team-slider>
  <div class="page-width">
    <div class="team-slider__header">
      {% if section.settings.heading != blank %}
        <h2 class="team-slider__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="team-slider__text">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="team-slider__nav">
      <button
        type="button"
        class="team-slider__arrow team-slider__arrow--prev"
        data-team-prev
        aria-label="Previous team members"
      >
        {% render 'icon', icon: 'arrow-left' %}
      </button>
      <button
        type="button"
        class="team-slider__arrow team-slider__arrow--next"
        data-team-next
        aria-label="Next team members"
      >
        {% render 'icon', icon: 'arrow-right' %}
      </button>
    </div>

    <div class="team-slider__viewport" data-team-viewport>
      <div class="team-slider__track" data-team-track>
        {% for block in section.blocks %}
          <article class="team-card" {{ block.shopify_attributes }}>
            <div class="team-card__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag: class: 'team-card__image', loading: 'lazy', alt: block.settings.name
                }}
              {% endif %}
            </div>

            <div class="team-card__content">
              <h3 class="team-card__name">{{ block.settings.name }}</h3>
              <p class="team-card__role">{{ block.settings.role }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Team slider",
  "tag": "section",
  "class": "section-team-slider",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Player’s behind the screen" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Smartwatches provide quick access to notifications, calls, messages, and apps right on your wrist, reducing the constantly check your phone.</p>"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Sophia Williams" },
        { "type": "text", "id": "role", "label": "Role", "default": "Head of Marketing" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team slider",
      "blocks": [{ "type": "member" }, { "type": "member" }, { "type": "member" }, { "type": "member" }]
    }
  ]
}
{% endschema %}
