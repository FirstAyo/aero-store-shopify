<section class="main-blog-custom">
  <div class="page-width">
    <div class="main-blog-custom__breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <span>{{ blog.title }}</span>
    </div>

    <div class="main-blog-custom__layout">
      <!-- Sidebar -->
      <aside class="main-blog-custom__sidebar">
        <div class="blog-sidebar__card blog-sidebar__card--search">
          <form action="{{ routes.search_url }}" method="get" role="search">
            <input type="hidden" name="type" value="article">

            <div class="blog-sidebar__search-wrap">
              <input
                type="search"
                name="q"
                class="blog-sidebar__search-input"
                placeholder="Search articles"
                value="{{ search.terms | escape }}"
              >
              <button type="submit" class="blog-sidebar__search-btn" aria-label="Search">🔍</button>
            </div>
          </form>
        </div>

        <div class="blog-sidebar__card">
          <h3 class="blog-sidebar__heading">Archive</h3>

          {% assign previous_month = '' %}
          {% for article in blog.articles limit: 6 %}
            {% assign current_month = article.published_at | date: '%B %Y' %}

            {% if current_month != previous_month %}
              <p class="blog-sidebar__archive-month">{{ current_month }}</p>
              {% assign previous_month = current_month %}
            {% endif %}

            <a href="{{ article.url }}" class="blog-sidebar__archive-link">
              {{ article.title }}
            </a>
          {% endfor %}
        </div>

        <div class="blog-sidebar__card">
          <h3 class="blog-sidebar__heading">Recent Post</h3>

          <div class="blog-sidebar__recent-list">
            {% for article in blog.articles limit: 3 %}
              <article class="blog-sidebar__recent-item">
                <a href="{{ article.url }}" class="blog-sidebar__recent-image-link">
                  {% if article.image %}
                    {{
                      article.image
                      | image_url: width: 220
                      | image_tag: class: 'blog-sidebar__recent-image', loading: 'lazy', alt: article.title
                    }}
                  {% endif %}
                </a>

                <div class="blog-sidebar__recent-content">
                  <h4 class="blog-sidebar__recent-title">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h4>

                  <p class="blog-sidebar__recent-date">
                    {{ article.published_at | date: '%b %d, %Y' }}
                  </p>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>

        <div class="blog-sidebar__card">
          <h3 class="blog-sidebar__heading">Tags</h3>

          <div class="blog-sidebar__tags">
            {% for tag in blog.all_tags %}
              <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="blog-sidebar__tag">
                {{ tag }}
              </a>
            {% endfor %}
          </div>
        </div>
      </aside>

      <!-- Content -->
      <div class="main-blog-custom__content">
        {% paginate blog.articles by 6 %}
          <div class="main-blog-custom__grid">
            {% for article in blog.articles %}
              <article class="blog-card blog-card--modern">
                <a href="{{ article.url }}" class="blog-card__image-link">
                  {% if article.image %}
                    {{
                      article.image
                      | image_url: width: 900
                      | image_tag: class: 'blog-card__image', loading: 'lazy', alt: article.title
                    }}
                  {% endif %}
                </a>

                <div class="blog-card__body">
                  <p class="blog-card__date">
                    {{ article.published_at | date: '%-m/%-d/%Y' }}
                  </p>

                  <h2 class="blog-card__title">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h2>

                  <div class="blog-card__excerpt">
                    {% if article.excerpt != blank %}
                      {{ article.excerpt | strip_html | truncatewords: 18 }}
                    {% else %}
                      {{ article.content | strip_html | truncatewords: 18 }}
                    {% endif %}
                  </div>

                  <div class="blog-card__footer-meta">
                    <span>By {{ article.author }}</span>

                    {% if article.tags.size > 0 %}
                      <span>•</span>
                      <span>{{ article.tags.first }}</span>
                    {% endif %}
                  </div>

                  <a href="{{ article.url }}" class="blog-card__read-more"> Read more </a>
                </div>
              </article>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="blog-pagination" role="navigation" aria-label="Pagination">
              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="blog-pagination__link">{{ part.title }}</a>
                {% else %}
                  {% if part.title == paginate.current_page %}
                    <span class="blog-pagination__link is-current">{{ part.title }}</span>
                  {% else %}
                    <span class="blog-pagination__link">{{ part.title }}</span>
                  {% endif %}
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="blog-pagination__link">Next</a>
              {% endif %}
            </nav>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main blog custom",
  "tag": "section",
  "class": "section-main-blog-custom",
  "settings": []
}
{% endschema %}
