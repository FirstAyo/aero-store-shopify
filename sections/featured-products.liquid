<section class="featured-products">
  <div class="page-width">
    <div class="featured-products__top">
      <div class="featured-products__intro">
        {% if section.settings.heading != blank %}
          <h2 class="featured-products__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="featured-products__text">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.collection != blank and section.settings.view_all_label != blank %}
        <a href="{{ section.settings.collection.url }}" class="featured-products__view-all">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    {% assign product_source = section.settings.collection.products %}
    {% assign product_limit = section.settings.products_to_show %}

    <div class="featured-products__grid">
      {% for product in product_source limit: product_limit %}
        {% render 'product-card-featured', product: product %}
      {% endfor %}
    </div>
  </div>

  {% render 'quick-view-modal' %}
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Highly Recommended"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Electronics products continue to drive innovation and shape the way we live, work, and interact with our environment.</p>"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
