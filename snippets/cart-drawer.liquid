{%- comment -%}
  Global cart drawer
  - Opens from header cart icon
  - Opens after add-to-cart
  - Uses AJAX cart endpoints
  - Includes expandable note + shipping panels
{%- endcomment -%}

<div class="cart-drawer" data-cart-drawer hidden>
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>

  <aside class="cart-drawer__panel" aria-label="Cart drawer">
    <div class="cart-drawer__header">
      <div class="cart-drawer__header-left">
        <span class="cart-drawer__check">✓</span>
        <h2 class="cart-drawer__title">Item added to your cart</h2>
      </div>

      <button
        type="button"
        class="cart-drawer__close"
        data-cart-drawer-close
        aria-label="Close cart drawer"
      >
        ×
      </button>
    </div>

    <div class="cart-drawer__body" data-cart-drawer-body>
      <div class="cart-drawer__items" data-cart-drawer-items>
        <p class="cart-drawer__empty">Your cart is empty.</p>
      </div>
    </div>

    <div class="cart-drawer__footer">
      <div class="cart-drawer__meta">
        <button
          type="button"
          class="cart-drawer__meta-link"
          data-cart-note-toggle
          aria-expanded="false"
        >
          ✎ Note
        </button>

        <span class="cart-drawer__meta-divider"></span>

        <button
          type="button"
          class="cart-drawer__meta-link"
          data-cart-shipping-toggle
          aria-expanded="false"
        >
          🚚 Shipping
        </button>
      </div>

      <!-- Note panel -->
      <div class="cart-drawer__panel-box" data-cart-note-panel hidden>
        <label for="CartDrawerNote" class="cart-drawer__panel-label"> Order note </label>

        <textarea
          id="CartDrawerNote"
          class="cart-drawer__note-input"
          data-cart-note-input
          rows="4"
          placeholder="Add a note to your order"
        ></textarea>

        <div class="cart-drawer__panel-actions">
          <button type="button" class="cart-drawer__panel-btn" data-cart-note-save>Save note</button>
        </div>
      </div>

      <!-- Shipping panel -->
      <div class="cart-drawer__panel-box" data-cart-shipping-panel hidden>
        <label class="cart-drawer__panel-label">Estimate shipping</label>

        <div class="cart-drawer__shipping-fields">
          <select class="cart-drawer__shipping-select" data-cart-shipping-country>
            <option value="">Country</option>
            <option value="Canada">Canada</option>
            <option value="United States">United States</option>
            <option value="United Kingdom">United Kingdom</option>
          </select>

          <input
            type="text"
            class="cart-drawer__shipping-input"
            data-cart-shipping-zip
            placeholder="Postal / ZIP code"
          >

          <button type="button" class="cart-drawer__panel-btn" data-cart-shipping-calc>Calculate</button>
        </div>

        <p class="cart-drawer__shipping-result" data-cart-shipping-result hidden></p>
      </div>

      <div class="cart-drawer__subtotal-row">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span class="cart-drawer__subtotal-value" data-cart-drawer-subtotal>$0.00</span>
      </div>

      <div class="cart-drawer__actions">
        <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart"> View Cart </a>

        <a href="/checkout" class="cart-drawer__checkout"> Check Out </a>
      </div>
    </div>
  </aside>
</div>
