{% case icon %}
  {% when 'menu' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>

  {% when 'close' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>

  {% when 'search' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <path d="M16 16l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>

  {% when 'account' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <path d="M4 20c1.8-4 5-6 8-6s6.2 2 8 6" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round"/>
    </svg>

  {% when 'heart' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M12 20s-7-4.4-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.6-7 10-7 10Z" stroke="currentColor" stroke-width="1.8" fill="none"/>
    </svg>

  {% when 'cart' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M3 5h2l2.2 10.2a1 1 0 0 0 1 .8h8.8a1 1 0 0 0 1-.8L20 8H7" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="10" cy="19" r="1.4" fill="currentColor"/>
      <circle cx="17" cy="19" r="1.4" fill="currentColor"/>
    </svg>

  {% when 'instagram' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <rect x="3.5" y="3.5" width="17" height="17" rx="5" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <circle cx="17.4" cy="6.6" r="1" fill="currentColor"/>
    </svg>

  {% when 'twitter' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M22 5.9c-.7.3-1.5.5-2.3.6.8-.5 1.4-1.2 1.7-2.1-.8.4-1.7.8-2.6.9A4 4 0 0 0 12 8.1c0 .3 0 .6.1.9A11.4 11.4 0 0 1 3.8 4.7a4 4 0 0 0 1.2 5.3c-.6 0-1.2-.2-1.7-.5 0 1.9 1.3 3.5 3.1 3.9-.3.1-.7.1-1 .1-.2 0-.5 0-.7-.1.5 1.5 1.9 2.7 3.7 2.7A8.1 8.1 0 0 1 2 18.6a11.5 11.5 0 0 0 6.3 1.8c7.5 0 11.7-6.3 11.7-11.7v-.5c.8-.5 1.5-1.2 2-2Z" fill="currentColor"/>
    </svg>

  {% when 'facebook' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M13.5 21v-7h2.3l.4-2.7h-2.7V9.6c0-.8.2-1.4 1.4-1.4h1.5V5.8c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.9v1.7H8V14h2.5v7h3Z" fill="currentColor"/>
    </svg>

  {% when 'youtube' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M21.6 8.2a2.8 2.8 0 0 0-2-2c-1.8-.5-7.6-.5-7.6-.5s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29 29 0 0 0 2 12a29 29 0 0 0 .4 3.8 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29 29 0 0 0 22 12a29 29 0 0 0-.4-3.8ZM10 15.5v-7l6 3.5-6 3.5Z" fill="currentColor"/>
    </svg>

  {% when 'arrow-left' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {% when 'arrow-right' %}
    <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" class="icon">
      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
{% endcase %}
