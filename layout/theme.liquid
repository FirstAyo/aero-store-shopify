<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <title>
      {{ page_title }}
      {% if current_tags %} – tagged "{{ current_tags | join: ', ' }}"{% endif %}
      {% if current_page != 1 %} – Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}
    </title>

    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}
    {{ 'animations.css' | asset_url | stylesheet_tag }}

    <script src="{{ 'navigation.js' | asset_url }}" defer></script>
    <script src="{{ 'slider.js' | asset_url }}" defer></script>
    <script src="{{ 'featured-products.js' | asset_url }}" defer></script>
    <script src="{{ 'countdown.js' | asset_url }}" defer></script>
    <script src="{{ 'testimonials.js' | asset_url }}" defer></script>
    <script src="{{ 'footer.js' | asset_url }}" defer></script>
  </head>

  <body>
    <a class="skip-to-content-link visually-hidden" href="#MainContent">Skip to content</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
